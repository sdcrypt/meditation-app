# Backend local development environment
# Copy to backend/.env for local Docker/dev use:
# cp backend/.env.local.example backend/.env

# Database
DATABASE_URL=postgresql://postgres:postgres@db:5432/meditation

# App environment
APP_ENV=development
FRONTEND_URL=http://localhost:5173
PASSWORD_RESET_URL_BASE=http://localhost:5173/reset-password
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# AWS / S3 media storage
AWS_ACCESS_KEY=your_local_or_dev_aws_access_key
AWS_SECRET_KEY=your_local_or_dev_aws_secret_key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=my-meditation-audio-2026

# Admin
ADMIN_API_KEY=local-dev-admin-key

# Auth/session
JWT_SECRET_KEY=local-dev-only-change-before-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
AUTH_COOKIE_NAME=still_session
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_DOMAIN=
CSRF_COOKIE_NAME=still_csrf
CSRF_HEADER_NAME=X-CSRF-Token
CSRF_TOKEN_EXPIRE_MINUTES=120

# Email
# Use "none" if you want local password reset links returned in the API response.
# Use "brevo" if you want to test real password reset emails locally.
EMAIL_PROVIDER=brevo
EMAIL_FROM=Still <no-reply@stillmorrow.in>
BREVO_API_KEY=your_brevo_api_key

# Logging
LOG_LEVEL=INFO
