# Meditation App - Environment Variables Template
# Copy to .env and fill in your values: cp .env.example .env

# Database
DATABASE_URL=postgresql://postgres:postgres@db:5432/meditation

# App environment
# Use "development" locally and "production" when deployed.
APP_ENV=development
FRONTEND_URL=http://localhost:5173
PASSWORD_RESET_URL_BASE=http://localhost:5173/reset-password
EMAIL_VERIFICATION_URL_BASE=http://localhost:5173/verify-email
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# AWS / S3 (required for media uploads)
AWS_ACCESS_KEY=your_aws_access_key
AWS_SECRET_KEY=your_aws_secret_key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=your_bucket_name

# Admin API Key (use a strong random value in production)
ADMIN_API_KEY=your_secure_admin_key

# Authentication
JWT_SECRET_KEY=replace_with_a_long_random_secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
AUTH_COOKIE_NAME=still_session
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_DOMAIN=
CSRF_COOKIE_NAME=still_csrf
CSRF_HEADER_NAME=X-CSRF-Token
CSRF_TOKEN_EXPIRE_MINUTES=120

# Email for password reset
# Local/dev option. This logs and returns the reset link for UI testing.
EMAIL_PROVIDER=none
EMAIL_FROM=Still <no-reply@example.com>
BREVO_API_KEY=

# Brevo transactional email option:
# EMAIL_PROVIDER=brevo
# EMAIL_FROM=Still <no-reply@yourdomain.com>
# BREVO_API_KEY=your_brevo_api_key

# Production auth/email checklist example:
# APP_ENV=production
# FRONTEND_URL=https://yourdomain.com
# PASSWORD_RESET_URL_BASE=https://yourdomain.com/reset-password
# EMAIL_VERIFICATION_URL_BASE=https://yourdomain.com/verify-email
# CORS_ORIGINS=["https://yourdomain.com"]
# AUTH_COOKIE_SECURE=true
# AUTH_COOKIE_SAMESITE=lax
# JWT_SECRET_KEY=replace_with_a_long_random_secret
# EMAIL_PROVIDER=brevo
# EMAIL_FROM=Still <no-reply@yourdomain.com>
# BREVO_API_KEY=your_brevo_api_key
