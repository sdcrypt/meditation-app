# Backend staging environment
# Do not commit the real staging .env file. Put real values in your host's secret manager.

# Database
DATABASE_URL=postgresql://staging_user:staging_password@staging-db-host:5432/meditation_staging

# App environment
APP_ENV=staging
FRONTEND_URL=https://staging.stillmorrow.in
PASSWORD_RESET_URL_BASE=https://staging.stillmorrow.in/reset-password
EMAIL_VERIFICATION_URL_BASE=https://staging.stillmorrow.in/verify-email
CORS_ORIGINS=["https://staging.stillmorrow.in"]

# AWS / S3 media storage
AWS_ACCESS_KEY=your_staging_aws_access_key
AWS_SECRET_KEY=your_staging_aws_secret_key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=your_staging_media_bucket

# Admin
ADMIN_API_KEY=replace_with_staging_random_admin_key

# Auth/session
JWT_SECRET_KEY=replace_with_staging_random_jwt_secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
AUTH_COOKIE_NAME=still_session
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_DOMAIN=.stillmorrow.in
CSRF_COOKIE_NAME=still_csrf
CSRF_HEADER_NAME=X-CSRF-Token
CSRF_TOKEN_EXPIRE_MINUTES=120

# Email
EMAIL_PROVIDER=brevo
EMAIL_FROM=Still Staging <no-reply@stillmorrow.in>
BREVO_API_KEY=your_staging_brevo_api_key

# Logging
LOG_LEVEL=INFO
