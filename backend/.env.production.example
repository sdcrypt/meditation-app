# Backend production environment
# Do not commit the real production .env file. Put real values in your host's secret manager.

# Database
DATABASE_URL=postgresql://production_user:production_password@production-db-host:5432/meditation

# App environment
APP_ENV=production
FRONTEND_URL=https://stillmorrow.in
PASSWORD_RESET_URL_BASE=https://stillmorrow.in/reset-password
CORS_ORIGINS=["https://stillmorrow.in","https://www.stillmorrow.in"]

# AWS / S3 media storage
AWS_ACCESS_KEY=your_production_aws_access_key
AWS_SECRET_KEY=your_production_aws_secret_key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=your_production_media_bucket

# Admin
ADMIN_API_KEY=replace_with_production_random_admin_key

# Auth/session
JWT_SECRET_KEY=replace_with_production_random_jwt_secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
AUTH_COOKIE_NAME=still_session
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_DOMAIN=.stillmorrow.in
CSRF_COOKIE_NAME=still_csrf
CSRF_HEADER_NAME=X-CSRF-Token
CSRF_TOKEN_EXPIRE_MINUTES=120

# Email
EMAIL_PROVIDER=brevo
EMAIL_FROM=Still <no-reply@stillmorrow.in>
BREVO_API_KEY=your_production_brevo_api_key

# Logging
LOG_LEVEL=INFO
